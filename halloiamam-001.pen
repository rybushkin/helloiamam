          "y": 70,
          "name": "s3title",
          "fill": "$brand-white",
          "content": "2. The Problem",
          "fontFamily": "$sans",
          "fontSize": 56,
          "fontWeight": "700"
        },
        {
          "type": "frame",
          "id": "MsaHF",
          "x": 96,
          "y": 170,
          "name": "s3left",
          "width": 680,
          "height": 620,
          "fill": "$brand-dark-soft",
          "cornerRadius": 20,
          "layout": "none",
          "children": [
            {
              "type": "rectangle",
