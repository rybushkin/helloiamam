            }
          ]
        },
        {
          "type": "frame",
          "id": "GLTdP",
          "x": 824,
          "y": 170,
          "name": "s3right",
          "width": 680,
          "height": 620,
          "fill": "#1A1A1C99",
          "cornerRadius": 20,
          "layout": "none",
          "children": [
            {
              "type": "rectangle",
              "id": "N2lJw",
              "x": 0,
              "y": 0,
              "name": "s3rimg",
              "fill": {
                "type": "image",
                "enabled": true,
                "url": "emoji/image 19.png",
                "mode": "fill"
              },
              "width": 680,
              "height": 620
            }
          ]
        },
        {
          "type": "text",
          "id": "DfAot",
          "x": 120,
          "y": 200,
          "name": "s3text",
          "fill": "$brand-white",
          "textGrowth": "fixed-width",
          "width": 1360,
          "content": "Armenia has cultural depth, but no simple emotional entry point for global audiences.\n\nArmenia is rich in everything modern travellers want:\n- food\n- wine\n- mountains\n- ancient culture\n- music\n- hospitality\n- identity\n- history\n- hidden places\n\nBut for many international audiences, Armenia still does not have a clear emotional handle.\n\nThey may know it exists.\n\nThey may know it is old, beautiful, or culturally rich.\n\nBut they do not yet know what Armenia feels like.",
          "lineHeight": 1.2,
          "fontFamily": "$sans",
          "fontSize": 24
        },
        {
          "type": "text",
          "id": "X29Ny",
          "x": 520,
          "y": 790,
          "name": "s3line",
          "fill": "$brand-yellow",
          "content": "Depth without a simple entry point",
          "fontFamily": "$serif-italic",
          "fontSize": 34,
          "fontWeight": "normal",
          "fontStyle": "italic"
        }
      ]
    },
    {
      "type": "frame",
      "id": "ZUXPq",
      "x": 5160,
      "y": 13000,
      "name": "Meet Armenia 04 Insight",
      "clip": true,
      "width": 1600,
      "height": 900,
      "fill": "$brand-dark",
      "layout": "none",
      "children": [
        {
          "type": "text",
          "id": "ZFpWU",
          "x": 96,
          "y": 70,
          "name": "s4title",
          "fill": "$brand-white",
          "content": "3. The Insight",
          "fontFamily": "$sans",
          "fontSize": 56,
          "fontWeight": "700"
        },
        {
          "type": "frame",
          "id": "gtQc9",
          "x": 96,
          "y": 160,
          "name": "s4col1",
          "width": 450,
          "height": 650,
          "fill": "$brand-dark-soft",
          "cornerRadius": 16,
          "layout": "none"
        },
        {
          "type": "frame",
          "id": "u0HUvV",
          "x": 575,
          "y": 160,
          "name": "s4col2",
          "width": 450,
          "height": 650,
          "fill": "$brand-dark-soft",
          "cornerRadius": 16,
          "layout": "none"
        },
        {
          "type": "frame",
          "id": "p9Jb0",
          "x": 1054,
          "y": 160,
          "name": "s4col3",
          "width": 450,
          "height": 650,
          "fill": "$brand-dark-soft",
          "cornerRadius": 16,
          "layout": "none"
        },
        {
          "type": "text",
          "id": "lP1qw",
          "x": 120,
          "y": 190,
          "name": "s4text",
          "fill": "$brand-white",
          "textGrowth": "fixed-width",
          "width": 1340,
          "content": "People do not choose places first. They choose feelings, stories, and identities.\n\nBefore people book a trip, they need a reason to care.\n\nA destination is not only a location.\n\nIt is a mood.\n\nA voice.\n\nA taste.\n\nA memory they have not had yet.\n\nArmenia should not be introduced as a checklist of attractions.\n\nIt should be introduced as a living cast of characters:\n- Wine\n- Mountains\n- Duduk\n- Lavash\n- Stone\n- Apricot\n- Yerevan\n- Monastery\n- Table\n- Grandma\n- Night\n- Road",
          "lineHeight": 1.15,
          "fontFamily": "$sans",
          "fontSize": 18
        }
      ]
    },
    {
      "type": "frame",
      "id": "R0vvME",
      "x": 6880,
      "y": 13000,
      "name": "Meet Armenia 05 Solution",
      "clip": true,
      "width": 1600,
      "height": 900,
      "fill": "$brand-dark",
      "layout": "none",
      "children": [
        {
          "type": "text",
          "id": "GQR73",
          "x": 96,
          "y": 70,
          "name": "s5title",
          "fill": "$brand-white",
          "content": "4. The Solution",
          "fontFamily": "$sans",
          "fontSize": 56,
          "fontWeight": "700"
        },
        {
          "type": "text",
          "id": "EPVGj",
          "x": 96,
          "y": 170,
          "name": "s5text",
          "fill": "$brand-white",
          "textGrowth": "fixed-width",
          "width": 1408,
          "content": "Meet Armenia: a character-based media brand for discovering the country.\n\nI am not a destination.\nI am a character.\nMeet Armenia.\n\nMeet Armenia turns the country into a living cast of cultural characters.\n\nEach character becomes:\n- a content format\n- a visual identity\n- a story arc\n- a guide\n- a route\n- a travel product\n\nThe brand does not simply tell people to visit Armenia.\n\nIt lets them meet Armenia first.",
          "lineHeight": 1.3,
          "fontFamily": "$sans",
          "fontSize": 24
        },
        {
          "type": "frame",
          "id": "CPpkZ",
