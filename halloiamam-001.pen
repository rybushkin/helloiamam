    {
      "type": "frame",
      "id": "l9gCL",
      "x": 3440,
      "y": 13000,
      "name": "Meet Armenia 03 Problem",
      "clip": true,
      "width": 1600,
      "height": 900,
      "fill": "$brand-dark",
      "layout": "none",
      "children": [
        {
          "type": "text",
